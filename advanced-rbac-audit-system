class RBACEngine:
    """Kullanıcı → Rol → İzin hiyerarşisini çözer."""

    def get_user_permissions(self, user: User) -> List[str]:
        """Tüm rolleri ve miras alınan izinleri birleştirir."""
        all_perms: Dict[str, Permission] = {}
        for role in user.roles:
            for perm in role.permissions:
                if perm.is_active:
                    all_perms[perm.name] = perm
        return list(all_perms.keys())

    def has_permission(self, user: User, resource: str, action: str) -> bool:
        """Wildcard (*) ve kesin eşleşme kontrolü."""
        permissions = self.get_user_permissions(user)
        checks = [
            f"{resource}:{action}",
            f"{resource}:*",
            "*:*",
        ]
        return any(p in permissions for p in checks)

    def check_or_raise(self, user: User, resource: str, action: str) -> None:
        if not self.has_permission(user, resource, action):
            raise HTTPException(
                status_code=status.HTTP_403_FORBIDDEN,
                detail=f"Erişim reddedildi: '{resource}:{action}' izni gerekli.",
            )


rbac_engine = RBACEngine()


