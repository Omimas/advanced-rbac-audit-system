@app.post("/auth/login", response_model=TokenResponse, tags=["Auth"])
async def login(body: LoginRequest, request: Request, db: Session = Depends(get_db)):
    meta = get_request_meta(request)
    user = db.query(User).filter_by(username=body.username).first()

    def _fail(detail: str, error: str = None):
        if user:
            user.failed_login_attempts += 1
            if user.failed_login_attempts >= MAX_FAILED_ATTEMPTS:
                user.is_locked = True
            db.flush()
            audit_logger.log(
                db, action=AuditAction.LOGIN, resource="auth",
                result=AuditResult.FAILURE, user_id=user.id,
                username=user.username, severity=AuditSeverity.CRITICAL,
                error_detail=error, **meta,
            )
            db.commit()
        raise HTTPException(status_code=401, detail=detail)

    if not user or not verify_password(body.password, user.hashed_password):
        _fail("Kullanıcı adı veya şifre hatalı.", "BAD_CREDENTIALS")

    if not user.is_active:
        _fail("Hesap devre dışı.", "INACTIVE")

    if user.is_locked:
        _fail("Hesap kilitli. Yöneticinizle iletişime geçin.", "LOCKED")

    # Başarılı giriş
    user.failed_login_attempts = 0
    user.last_login = datetime.now(timezone.utc)

    access_token  = create_token(
        {"sub": str(user.id), "username": user.username, "type": "access"},
        timedelta(minutes=ACCESS_TOKEN_EXPIRE_MINUTES),
    )
    refresh_token = create_token(
        {"sub": str(user.id), "username": user.username, "type": "refresh"},
        timedelta(minutes=REFRESH_TOKEN_EXPIRE_MINUTES),
    )

    audit_logger.log(
        db, action=AuditAction.LOGIN, resource="auth",
        result=AuditResult.SUCCESS, user_id=user.id,
        username=user.username, severity=AuditSeverity.LOW, **meta,
    )
    db.commit()
    return TokenResponse(access_token=access_token, refresh_token=refresh_token)


@app.post("/auth/refresh", response_model=TokenResponse, tags=["Auth"])
async def refresh(body: RefreshRequest, db: Session = Depends(get_db)):
    payload = decode_token(body.refresh_token)
    if payload.get("type") != "refresh":
        raise HTTPException(status_code=401, detail="Yenileme tokeni gerekli.")
    if is_token_blacklisted(payload["jti"], db):
        raise HTTPException(status_code=401, detail="Token iptal edilmiş.")

    user_id = int(payload["sub"])
    user = db.query(User).filter_by(id=user_id, is_active=True).first()
    if not user:
        raise HTTPException(status_code=401, detail="Kullanıcı bulunamadı.")

    # Eski yenileme tokenini iptal et
    db.add(TokenBlacklist(
        jti=payload["jti"], user_id=user_id,
        expires_at=datetime.fromtimestamp(payload["exp"], tz=timezone.utc),
    ))
    access_token  = create_token(
        {"sub": str(user.id), "username": user.username, "type": "access"},
        timedelta(minutes=ACCESS_TOKEN_EXPIRE_MINUTES),
    )
    refresh_token = create_token(
        {"sub": str(user.id), "username": user.username, "type": "refresh"},
        timedelta(minutes=REFRESH_TOKEN_EXPIRE_MINUTES),
    )
    audit_logger.log(
        db, action=AuditAction.TOKEN_REFRESH, resource="auth",
        result=AuditResult.SUCCESS, user_id=user.id, username=user.username,
        severity=AuditSeverity.LOW,
    )
    db.commit()
    return TokenResponse(access_token=access_token, refresh_token=refresh_token)


@app.post("/auth/logout", status_code=204, tags=["Auth"])
async def logout(
    credentials: HTTPAuthorizationCredentials = Depends(bearer_scheme),
    current_user: User = Depends(get_current_user),
    request: Request = None,
    db: Session = Depends(get_db),
):
    payload = decode_token(credentials.credentials)
    expires = datetime.fromtimestamp(payload["exp"], tz=timezone.utc)
    db.add(TokenBlacklist(jti=payload["jti"], user_id=current_user.id, expires_at=expires))
    meta = get_request_meta(request) if request else {}
    audit_logger.log(
        db, action=AuditAction.LOGOUT, resource="auth",
        result=AuditResult.SUCCESS, user_id=current_user.id,
        username=current_user.username, severity=AuditSeverity.LOW, **meta,
    )
    db.commit()


