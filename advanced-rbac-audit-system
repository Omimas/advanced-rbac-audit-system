# UYGULAMA BAŞLANGICI — Veritabanı + Seed
# ─────────────────────────────────────────────
def seed_database(db: Session):
    """Varsayılan roller, izinler ve yönetici kullanıcısı oluşturur."""

    # ── İzinler ──────────────────────────────
    base_permissions = [
        ("users",       "read"),   ("users",       "write"),  ("users",  "delete"),
        ("roles",       "read"),   ("roles",       "write"),
        ("permissions", "read"),   ("permissions", "write"),
        ("audit",       "read"),
        ("reports",     "read"),   ("reports",     "export"),
        ("settings",    "read"),   ("settings",    "write"),
        ("*",           "*"),
    ]
    perm_objs: Dict[str, Permission] = {}
    for resource, action in base_permissions:
        name = f"{resource}:{action}"
        p = db.query(Permission).filter_by(name=name).first()
        if not p:
            p = Permission(name=name, resource=resource, action=action,
                           description=f"{resource} kaynak üzerinde {action} yetkisi")
            db.add(p)
            db.flush()
        perm_objs[name] = p

    # ── Roller ───────────────────────────────
    role_defs = [
        ("super_admin", "Süper Yönetici", None,          True,  ["*:*"]),
        ("admin",       "Yönetici",       "super_admin", True,  [
            "users:read","users:write","users:delete",
            "roles:read","roles:write","permissions:read","permissions:write",
            "audit:read","reports:read","reports:export","settings:read","settings:write",
        ]),
        ("manager",     "Yöner",          "admin",       True,  [
            "users:read","users:write","reports:read","reports:export",
        ]),
        ("auditor",     "Denetçi",        None,          True,  [
            "audit:read","users:read","reports:read",
        ]),
        ("user",        "Kullanıcı",      "manager",     True,  [
            "users:read",
        ]),
    ]
    role_objs: Dict[str, Role] = {}
    for name, dname, parent_name, is_sys, perms in role_defs:
        r = db.query(Role).filter_by(name=name).first()
        if not r:
            parent = role_objs.get(parent_name) if parent_name else None
            r = Role(name=name, display_name=dname, is_system=is_sys,
                     parent_id=parent.id if parent else None)
            db.add(r)
            db.flush()
        role_objs[name] = r

        for pname in perms:
            perm = perm_objs.get(pname)
            if perm and not db.query(RolePermission).filter_by(role_id=r.id, permission_id=perm.id).first():
                db.add(RolePermission(role_id=r.id, permission_id=perm.id))

    # ── Yönetici Kullanıcı ───────────────────
    admin_pass = os.getenv("ADMIN_PASSWORD", "Admin@123!")
    if not db.query(User).filter_by(username="admin").first():
        admin = User(
            username="admin", email="admin@example.com",
            full_name="Sistem Yöneticisi",
            hashed_password=hash_password(admin_pass),
        )
        db.add(admin)
        db.flush()
        db.add(UserRole(user_id=admin.id, role_id=role_objs["super_admin"].id))
        logger.info("✅ Yönetici oluşturuldu: admin / %s", admin_pass)

    db.commit()
    logger.info("✅ Veritabanı seed tamamlandı.")


@app.on_event("startup")
async def startup():
    Base.metadata.create_all(bind=engine)
    with SessionLocal() as db:
        seed_database(db)
    logger.info("🚀 %s v%s başlatıldı", APP_TITLE, APP_VERSION)
    logger.info("📖 API Belgeleri: http://localhost:8000/docs")


