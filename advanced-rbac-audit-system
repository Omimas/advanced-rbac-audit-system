@app.get("/audit/report", response_model=AuditReport, tags=["Denetim"])
async def audit_report(
    current_user: User = Depends(require_permission("audit", "read")),
    db: Session = Depends(get_db),
    days: int = 30,
):
    from sqlalchemy import func, desc
    since = datetime.now(timezone.utc) - timedelta(days=days)
    logs = db.query(AuditLog).filter(AuditLog.timestamp >= since)

    total    = logs.count()
    success  = logs.filter_by(result=AuditResult.SUCCESS).count()
    failure  = logs.filter_by(result=AuditResult.FAILURE).count()
    denied   = logs.filter_by(result=AuditResult.DENIED).count()
    critical = logs.filter_by(severity=AuditSeverity.CRITICAL).count()

    top_users_raw = (
        db.query(AuditLog.username, func.count(AuditLog.id).label("cnt"))
        .filter(AuditLog.timestamp >= since)
        .group_by(AuditLog.username)
        .order_by(desc("cnt"))
        .limit(10)
        .all()
    )
    top_resources_raw = (
        db.query(AuditLog.resource, func.count(AuditLog.id).label("cnt"))
        .filter(AuditLog.timestamp >= since)
        .group_by(AuditLog.resource)
        .order_by(desc("cnt"))
        .limit(10)
        .all()
    )
    actions_raw = (
        db.query(AuditLog.action, func.count(AuditLog.id).label("cnt"))
        .filter(AuditLog.timestamp >= since)
        .group_by(AuditLog.action)
        .all()
    )

    return AuditReport(
        period_start=since, period_end=datetime.now(timezone.utc),
        total_events=total, success_count=success,
        failure_count=failure, denied_count=denied,
        critical_events=critical,
        top_users=[{"username": r[0], "count": r[1]} for r in top_users_raw],
        top_resources=[{"resource": r[0], "count": r[1]} for r in top_resources_raw],
        actions_breakdown={r[0]: r[1] for r in actions_raw},
    )


